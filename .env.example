PLANNER_PROVIDER=mock
VIDEO_PROVIDER=placeholder
TTS_PROVIDER=auto
TTS_AUDIO_FORMAT=flac
TTS_SCENE_MODE=per_scene

ELEVENLABS_ENABLED=false
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
